# Optional: only change this if you keep production variables in another file.
APP_ENV_FILE=.env

MYSQL_HOST=db
MYSQL_DATABASE=bitacora_mw
MYSQL_USER=bitacora_user
MYSQL_PASSWORD=change_this_database_password
MYSQL_ROOT_PASSWORD=change_this_root_password

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=bitacora@example.com
SMTP_PASSWORD=change_this_smtp_password
SMTP_FROM=bitacora@example.com
SMTP_VERIFY_TLS=true

# Set false only for a temporary HTTP-only test. Use true with HTTPS in production.
SESSION_SECURE=true
SESSION_SAMESITE=Lax
BITACORA_STORAGE_PATH=/var/www/html/storage/bitacoras_pdf
